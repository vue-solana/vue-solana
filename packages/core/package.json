{
  "name": "@vue-solana/core",
  "version": "0.3.3",
  "description": "Framework-agnostic primitives for Vue Solana libraries.",
  "license": "MIT",
  "keywords": [
    "solana",
    "vue",
    "nuxt",
    "web3",
    "wallet",
    "rpc"
  ],
  "homepage": "https://vue-solana-docs.vercel.app/packages/core",
  "bugs": {
    "url": "https://github.com/vue-solana/vue-solana/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vue-solana/vue-solana.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./clusters": {
      "types": "./dist/clusters.d.ts",
      "import": "./dist/clusters.mjs",
      "require": "./dist/clusters.cjs"
    },
    "./ios-wallet": {
      "types": "./dist/ios-wallet.d.ts",
      "import": "./dist/ios-wallet.mjs",
      "require": "./dist/ios-wallet.cjs"
    },
    "./mobile-wallet": {
      "types": "./dist/mobile-wallet.d.ts",
      "import": "./dist/mobile-wallet.mjs",
      "require": "./dist/mobile-wallet.cjs"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.mjs",
      "require": "./dist/rpc.cjs"
    },
    "./transaction": {
      "types": "./dist/transaction.d.ts",
      "import": "./dist/transaction.mjs",
      "require": "./dist/transaction.cjs"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.mjs",
      "require": "./dist/wallet.cjs"
    },
    "./wallet-standard": {
      "types": "./dist/wallet-standard.d.ts",
      "import": "./dist/wallet-standard.mjs",
      "require": "./dist/wallet-standard.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solana-mobile/wallet-standard-mobile": "^0.5.3",
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/web3-compat": "^0.0.21",
    "@wallet-standard/app": "^1.1.1",
    "@wallet-standard/base": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "unbuild": "^3.5.0"
  }
}
