{
  "name": "vue-solana",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter './packages/*' build",
    "build:examples": "pnpm build:example:vue && pnpm build:example:nuxt",
    "build:example:vue": "pnpm --filter @vue-solana/example-vue-vite build",
    "build:example:nuxt": "pnpm --filter @vue-solana/example-nuxt build",
    "build:docs": "pnpm --filter docs build",
    "dev": "pnpm -r --parallel dev",
    "dev:vue": "pnpm --filter @vue-solana/example-vue-vite dev",
    "dev:nuxt": "pnpm --filter @vue-solana/example-nuxt dev",
    "dev:docs": "pnpm --filter docs dev",
    "generate:docs": "pnpm --filter docs generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint-staged": "lint-staged",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky",
    "release": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@nuxt/kit": "^4.4.6",
    "@types/node": "^22.15.29",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nuxt": "^4.4.6",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "unbuild": "^3.5.0",
    "vue": "^3.5.16"
  },
  "packageManager": "pnpm@10.11.1"
}
